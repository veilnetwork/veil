{# Secondary decoy page for Caddy-fronted webtunnel (anti-censorship P1 #3).
   Hit by active probes following the /about link от index.html. -#}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>About — {{ decoy_site_name | default('Notes &amp; Drafts') }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="canonical" href="https://{{ veil_host }}/about.html">
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            line-height: 1.6;
            color: #2c2c2c;
            max-width: 720px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
            background: #fdfdfd;
        }
        h1, h2 { font-weight: 600; }
        h2 { margin-top: 2rem; border-bottom: 1px solid #e5e5e5; padding-bottom: 0.25rem; }
        nav { margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid #e5e5e5; }
        nav a { margin-right: 1.5rem; color: #555; text-decoration: none; }
        nav a:hover { color: #000; text-decoration: underline; }
    </style>
</head>
<body>
    <nav>
        <a href="/">Home</a>
        <a href="/about.html">About</a>
        <a href="/feed.xml">RSS</a>
    </nav>

    <h1>About this site</h1>
    <p>
        Small personal site для notes, drafts, и occasional longer-form
        writing.  Updated when there's something worth saying.
    </p>

    <h2>Tech</h2>
    <p>
        Static site, generated с Hugo и hosted on а modest VPS.  No
        analytics, no comments section, no tracking pixels.  RSS is
        the canonical subscription channel — older posts stay
        permalinked.
    </p>

    <h2>Contact</h2>
    <p>
        Email is the most reliable way к reach me.  The address is
        printed in the footer of the RSS feed (anti-spam-harvest).
    </p>
</body>
</html>
