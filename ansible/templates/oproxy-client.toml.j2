# Generated by ansible — DO NOT EDIT manually.
# oproxy-client config (per-host, in /etc/oproxy/client.toml).
socket_path     = "/var/lib/veil/app.sock"
server_node_id  = "{{ oproxy_server_node_id }}"
server_app_name = "{{ oproxy_server_app_name | default('testnet-proxy') }}"

# Inbound listeners.  SOCKS5 + HTTP CONNECT ара the cross-platform
# defaults; add `tproxy` only on Linux / Keenetic с iptables setup.
[[inbound]]
kind   = "socks5"
listen = "{{ oproxy_socks5_listen | default('127.0.0.1:1080') }}"

[[inbound]]
kind   = "http"
listen = "{{ oproxy_http_listen | default('127.0.0.1:8080') }}"
