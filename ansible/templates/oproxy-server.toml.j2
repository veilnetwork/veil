# Generated by ansible — DO NOT EDIT manually.
# oproxy-server config (per-host, in /etc/oproxy/server.toml).
socket_path     = "/var/lib/veil/app.sock"
app_name        = "{{ oproxy_app_name | default('testnet-proxy') }}"

# Empty list = allow ALL callers (open proxy mode).  Restrict by populating:
allowed_node_ids = {{ (oproxy_allowed_node_ids | default([])) | to_json }}

# Block RFC1918 / loopback / metadata destinations.  Recommended `false`
# for production proxies; toggle for internal-network probing.
allow_private    = {{ (oproxy_allow_private | default(false)) | string | lower }}
