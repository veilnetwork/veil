# ogate.toml — generated by ansible deploy-ogate.yml
# Host: {{ inventory_hostname }} (manifest name: {{ inv_to_cfg[inventory_hostname] }})

network       = "{{ ogate_network }}"
app           = "{{ ogate_app }}"
mode          = "{{ ogate_mode }}"
socket_path   = "{{ ogate_socket_path }}"
iface_name    = "{{ ogate_iface_name }}"
mtu           = {{ ogate_mtu }}
local_addr_v4 = "{{ host_to_ogate_addr[inventory_hostname] }}"
prefix_v4     = {{ ogate_prefix_v4 }}
endpoint_id   = {{ ogate_endpoint_id }}

{% for h in ansible_play_hosts if h != inventory_hostname %}
[[peers]]
node_id = "{{ hostvars[h].veil_node_id }}"
addr_v4 = "{{ host_to_ogate_addr[h] }}"
name    = "{{ h }}"

{% endfor %}
