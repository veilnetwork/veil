# docker/.env.example — copy to ../.env and fill in HOST + EMAIL.
#
# Usage: cp docker/.env.example .env (in the repo root, NOT in docker/).
# docker compose reads .env from the current working directory.

# ── Required ─────────────────────────────────────────────────────────────
# DNS name that resolves to this host's public IP.  Let's Encrypt issues
# the cert for exactly this name; veil advertises it to peers as the
# canonical endpoint.
HOST=bootstrap.example.com

# Contact for Let's Encrypt renewal notices.
EMAIL=admin@example.com

# ── Image ────────────────────────────────────────────────────────────────
# Pre-built Docker Hub image.  Override to use a locally built image
# (e.g., VEIL_IMAGE=veil-bootstrap:latest) or pin a specific tag.
VEIL_IMAGE=veilnetwork/veil:latest

# ── Optional ─────────────────────────────────────────────────────────────

# Set to 1 to hit Let's Encrypt's staging endpoint (no rate limits, untrusted
# cert).  Use this for the first couple of test runs so a typo in HOST
# doesn't burn you a real-cert attempt.
# STAGING=1

# Node role: core (default — DHT, relay, gateway) or leaf (mobile/lightweight).
# ROLE=core

# PoW difficulty for the generated identity.  Core wants ≥24.
# Higher = more mining CPU on first boot.
# DIFFICULTY=24

# Ports.  TCP/TLS/QUIC/WSS all listen on 0.0.0.0 inside the container;
# docker compose publishes them on the host.  WSS and QUIC share the
# 8443 port number (WSS over TCP, QUIC over UDP — they do not conflict).
# TCP_PORT=5555
# TLS_PORT=9906
# QUIC_PORT=8443
# WSS_PORT=8443

# Mesh UDP beacon bind.  Used for local-LAN autodiscovery; leave default
# unless you need to move off port 6666.
# MESH_UDP_PORT=6666

# Prometheus metrics HTTP endpoint.  Leave empty to disable.
# When set, the node serves /metrics on this port.
# METRICS_PORT=19999
