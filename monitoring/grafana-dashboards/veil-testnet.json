    {
      "id": 11,
      "title": "Per-node session count (current)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 24,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "veil_active_sessions",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 3,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "title": "Session rekey throughput (rate /s) — phase 6.32-6.33 visibility",
      "description": "Per-stage rekey FSM counters.  Healthy: init.tx ≈ init.rx ≈ ack.tx ≈ ack.rx (small lag OK).  Drift between init.tx and ack.rx ⇒ acks dropped on the wire OR session torn down before completion (paired with active-sessions dip).",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 42,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_rekey_init_sent_total[1m])",
          "legendFormat": "{{host}} init.tx",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_rekey_init_received_total[1m])",
          "legendFormat": "{{host}} init.rx",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_rekey_ack_sent_total[1m])",
          "legendFormat": "{{host}} ack.tx",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_rekey_ack_received_total[1m])",
          "legendFormat": "{{host}} ack.rx",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      }
    },
    {
      "id": 21,
      "title": "Rekey-grace fallback + cap evictions — back-to-back rekey early-warning",
      "description": "Decrypt fallback (left) is the rekey-grace mechanism working as designed — frames in flight at rekey boundary recovered via prev cipher.  Healthy: low non-zero rate paired with rekey rate.  Cap evictions (right) MUST stay at 0 — non-zero ⇒ rekeys arriving faster than 30s grace expires, ring buffer of 3 prev ciphers overflowed, real risk of session-teardown decrypt-failure storm.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 48,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_rekey_decrypt_fallback_total[1m])",
          "legendFormat": "{{host}} fallback (healthy)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_rekey_grace_cap_evictions_total[1m])",
          "legendFormat": "{{host}} cap-evict (ALERT > 0)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      }
    },
    {
      "id": 22,
      "title": "Iterative-DHT fallback rate (Phase 6.50.b)",
      "description": "Fires when legacy RouteRequest flood (TTL=7) exhausts retries and we fall through to RecursiveQuery(FIND_NODE).  Triggered = total fallback invocations.  Resolved = RecursiveResponse arrived within RECURSIVE_TIMEOUT (10s) and dispatcher auto-populated route_cache.  Miss = timeout without response.  Healthy: triggered rate proportional to route-miss-rate; resolved/(resolved+miss) ratio > 50%.  High miss rate indicates network diameter exceeds RecursiveQuery TTL=40 OR CPU pressure dropping reverse-path responses.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 54,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_dht_fallback_triggered_total[1m])",
          "legendFormat": "{{host}} triggered",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_dht_fallback_resolved_total[1m])",
          "legendFormat": "{{host}} resolved",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_dht_fallback_miss_total[1m])",
          "legendFormat": "{{host}} miss",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      }
    },
    {
      "id": 24,
      "title": "DHT fallback adaptive timeout + backpressure (Phase 6.50.b slice 5)",
      "description": "LEFT axis: effective timeout (ms) — flat at baseline `dht_fallback_timeout_ms` when adaptive=false; climbs 1.5× under sustained miss-rate >50% when adaptive=true, clamped 1000-60000ms.  RIGHT axis: backpressure-skipped events/s — rises when `pending_recursive` map exceeds `dht_fallback_backpressure_threshold_pct` (default 75%) of cap.  Operator alerts: timeout climbing rapidly = network is congesting; skipped non-zero = dispatcher CPU saturated.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 60,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "veil_dht_fallback_effective_timeout_ms",
          "legendFormat": "{{host}} effective_timeout_ms",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_dht_fallback_skipped_backpressure_total[1m])",
          "legendFormat": "{{host}} skipped/s (ALERT > 0)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0
        }
      }
    },
    {
      "id": 23,
      "title": "DHT fallback resolution ratio (partition health)",
      "description": "Per-node ratio resolved/(resolved+miss) over the last 5 min.  This is the **partition-health signal**: 1.0 = every fallback succeeds (sparse mesh handled well by DHT), 0.0 = every fallback times out (network fragmented past RecursiveQuery's TTL=40 reach OR responses are being dropped/lost).  Threshold guidance: > 0.5 = healthy, 0.2-0.5 = degraded, < 0.2 = partition suspected.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 54,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_dht_fallback_resolved_total[5m]) / (rate(veil_dht_fallback_resolved_total[5m]) + rate(veil_dht_fallback_miss_total[5m]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.2
              },
              {
                "color": "green",
                "value": 0.5
              }
            ]
          }
        }
      }
    },
    {
      "id": 30,
      "title": "Buffer pool throughput (Phase 6.50.d — hot path recycle rate)",
      "description": "cache_hit_total = pool returned a cached buffer (zero malloc).  fallback_alloc_total = bucket empty, fresh heap alloc (rare in steady state).  Healthy: hit/(hit+fb) > 99.99%.  Spike in fb rate = bucket cap too small or burst exceeds pool budget.  return_anomaly = caller mutated buffer capacity in a way pool can't cache; should be 0.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 66,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_bufpool_cache_hit_total[1m])",
          "legendFormat": "{{host}} cache_hit",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_bufpool_fallback_alloc_total[1m])",
          "legendFormat": "{{host}} fallback",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(veil_bufpool_overflow_drop_total[1m])",
          "legendFormat": "{{host}} overflow_drop",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      }
    },
    {
      "id": 31,
      "title": "Buffer pool inflight + peak (cache occupancy)",
      "description": "cached_inflight = current count of buffers held in pool free lists across all 3 size buckets (256B / 4KiB / 64KiB).  cached_peak = high watermark.  Plateau within cap is healthy.  Climbing peak + low inflight = high churn (acquire/release cycle).",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 66,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "veil_bufpool_cached_inflight",
          "legendFormat": "{{host}} inflight",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "veil_bufpool_cached_peak",
          "legendFormat": "{{host}} peak",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 32,
      "title": "Session-plane state (live + tx/outbox registries)",
      "description": "live_sessions = open transport sessions.  session_tx_registry = peers with outbound frame channel.  session_outbox = peers with RPC outbox.  Should track 1:1 in steady state; divergence indicates teardown lag (sessions cleaned up faster than registries OR vice-versa).",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 72,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "veil_state_live_sessions",
          "legendFormat": "{{host}} live",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "veil_state_session_tx_registry",
          "legendFormat": "{{host}} tx_reg",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "veil_state_session_outbox",
          "legendFormat": "{{host}} outbox",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 33,
      "title": "Routing state — route_cache + DHT routing table",
