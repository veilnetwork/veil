{
  "title": "Veil testnet 8-node (v6 — bufpool + state-size gauges)",
  "uid": "veil-testnet-v2",
  "tags": [
    "veil"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m"
    ],
    "time_options": [
      "5m",
      "15m",
      "30m",
      "1h",
      "3h",
      "6h",
      "12h",
      "24h"
    ]
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Active sessions per node",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "veil_active_sessions",
          "legendFormat": "{{host}} ({{role}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 2,
      "title": "Transport bytes RX / TX (per-node)",
