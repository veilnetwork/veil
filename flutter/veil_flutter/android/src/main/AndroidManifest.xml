<?xml version="1.0" encoding="utf-8"?>
<!--
  Plugin AndroidManifest для veil_flutter (Epic 489.3 + 489.6).

  Permissions:
    * INTERNET — every consumer needs to dial out к peers.
    * FOREGROUND_SERVICE — Epic 489.6: keep daemon alive when app
      backgrounded.  Required от Android 9 (API 28) onward.
    * FOREGROUND_SERVICE_REMOTE_MESSAGING — Android 14 (API 34)
      sub-permission specific to "messaging-style" foreground
      services.  Closest fit к veil's "continuously receive
      messages over the internet" purpose.
    * POST_NOTIFICATIONS — Android 13 (API 33) runtime permission
      for displaying notifications (the foreground-service
      notification falls under this).  Apps prompt the user to
      grant this at first-run.

  Service:
    * `VeilDaemonService` — the foreground-service holder.
      `exported=false` means only this app can `bindService`
      / `startService` к it (sandbox hardening).
      `foregroundServiceType="remoteMessaging|microphone|camera"` declares
      every type the service may use. The runtime call selects only the
      capture devices that are currently enabled — see service code.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_REMOTE_MESSAGING" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- WAKE_LOCK: the foreground service holds a PARTIAL wake lock so the CPU
         keeps running with the screen off. Without it Doze suspends the CPU
         between maintenance windows and the daemon's socket keepalive + the
         onion circuit heartbeat timers stop firing, so the first-hop TCP dies
         and inbound messages stall until the next wake. Held only while the
         opt-in background service runs. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application>
        <service
            android:name=".VeilDaemonService"
            android:exported="false"
            android:foregroundServiceType="remoteMessaging|microphone|camera" />
    </application>
</manifest>
