# Docker context exclusions — protect dev secrets, speed up builds, and cap the
# tarball uploaded to the daemon / remote builder.

# Version control
.git
.gitignore
.github

# Build artifacts
target
**/*.rs.bk
**/Cargo.lock.bak

# Local development environments
ansible/.venv
ansible/__pycache__
.venv
.envrc
.direnv
flutter/veil_flutter/build
flutter/veil_flutter/.dart_tool
flutter/veil_flutter/.pub-cache

# Local secrets and generated keys (cert.pem is checked in for testnet, the
# corresponding private key is NOT). The release-signing identity lives at the
# repo root (git-ignored) — exclude it EXPLICITLY so `docker build .` with a
# root context never ships it to the daemon / remote builder / image layer.
# (The earlier `*.identity.toml` glob did NOT match `release-identity.toml`
# because of the dash, so the key was silently included.)
release.key
release.pub
release-identity.toml
*-identity.toml
*.identity.toml
ssl/*.pem
ssl/*.key
*.pkcs8
*.private.toml

# Local config / state files spawned by sim / devnet
devnet-*
sim-*
.veil-runtime
veil-data

# OS noise
.DS_Store
Thumbs.db
*~
.vscode
.idea

# Editor caches
*.swp
*.swo
*.bak

# Cargo caches (only the workspace target/ — sccache lives outside repo)
.cargo-cache

# Ansible artifacts
ansible/*.retry
ansible/host_vars
ansible/group_vars/secret.yml
